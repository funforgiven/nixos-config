new file mode 100644
index 0000000..731c1bc
--- /dev/null
+++ b/src/io/test/socketreconnect.cpp
@@ -0,0 +1,35 @@
+#include <qobject.h>
+#include <qtemporarydir.h>
+#include <qtest.h>
+#include <qtestcase.h>
+
+#include "../socket.hpp"
+
+class TestSocketReconnect: public QObject {
+	Q_OBJECT;
+
+private slots:
+	void reconnectsAfterInitialFailure();
+};
+
+void TestSocketReconnect::reconnectsAfterInitialFailure() {
+	QTemporaryDir directory;
+	QVERIFY(directory.isValid());
+
+	Socket socket;
+	auto errorCount = 0;
+	QObject::connect(&socket, &Socket::error, &socket, [&] {
+		errorCount += 1;
+		socket.setConnected(false);
+	});
+	socket.setPath(directory.filePath("missing.sock"));
+	socket.setConnected(true);
+	QTRY_COMPARE_WITH_TIMEOUT(errorCount, 1, 1000);
+
+	socket.setConnected(true);
+	QTRY_COMPARE_WITH_TIMEOUT(errorCount, 2, 1000);
+}
+
+QTEST_MAIN(TestSocketReconnect);
+
+#include "socketreconnect.moc"
