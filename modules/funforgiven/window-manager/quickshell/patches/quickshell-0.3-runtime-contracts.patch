+void PwDevice::addRouteAvailability(const spa_pod* param, bool enumerated) {
+	auto route = RouteAvailability {};
+	route.availability = SPA_PARAM_AVAILABILITY_unknown;
+	const auto* availabilityProp = spa_pod_find_prop(param, nullptr, SPA_PARAM_ROUTE_available);
+
+	if (availabilityProp != nullptr) {
+		spa_pod_get_id(&availabilityProp->value, &route.availability);
+	}
+
+	if (enumerated) {
+		const auto* devicesProp = spa_pod_find_prop(param, nullptr, SPA_PARAM_ROUTE_devices);
+		if (devicesProp == nullptr || !spa_pod_is_array(&devicesProp->value)) return;
+
+		const auto* devices = reinterpret_cast<const spa_pod_array*>(&devicesProp->value);
+		if (SPA_POD_ARRAY_VALUE_TYPE(devices) != SPA_TYPE_Int
+		    || SPA_POD_ARRAY_VALUE_SIZE(devices) != sizeof(qint32))
+		{
+			return;
+		}
+
+		const qint32* device = nullptr;
+		SPA_POD_ARRAY_FOREACH(devices, device) { route.devices.append(*device); }
+		this->stagingEnumeratedRoutes.append(route);
+	} else {
+		const auto* deviceProp = spa_pod_find_prop(param, nullptr, SPA_PARAM_ROUTE_device);
+		qint32 device = 0;
+		if (deviceProp == nullptr || spa_pod_get_int(&deviceProp->value, &device) < 0) return;
+
+		route.devices.append(device);
+		this->stagingActiveRoutes.append(route);
@@ -147,0 +230,18 @@ bool PwDevice::hasRouteDevice(qint32 routeDevice) const {
+bool PwDevice::hasAvailableRoutes(qint32 routeDevice) const {
+	for (const auto& route: this->activeRoutes) {
+		if (route.devices.contains(routeDevice)) {
+			return route.availability != SPA_PARAM_AVAILABILITY_no;
+		}
+	}
+
+	auto found = false;
+	for (const auto& route: this->enumeratedRoutes) {
+		if (route.devices.contains(routeDevice)) {
+			found = true;
+			if (route.availability != SPA_PARAM_AVAILABILITY_no) return true;
+		}
+	}
+
+	return !found;
+}
+
