+void SplitParser::setMaximumBufferSize(qint64 size) {
+	if (size < -1) size = -1;
+	if (size == this->mMaximumBufferSize) return;
+
+	this->mMaximumBufferSize = size;
+	emit this->maximumBufferSizeChanged();
+}
+
+void SplitParser::enforceBufferLimit(QByteArray& buffer) {
+	if (this->mMaximumBufferSize < 0 || buffer.size() <= this->mMaximumBufferSize) return;
+
+	const auto size = static_cast<qint64>(buffer.size());
+	buffer.clear();
+	emit this->bufferLimitExceeded(size);
+}
