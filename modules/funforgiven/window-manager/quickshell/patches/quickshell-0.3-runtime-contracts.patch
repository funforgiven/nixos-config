+void TestSplitParser::bufferLimit() { // NOLINT
+	auto parser = SplitParser();
+	auto readSpy = QSignalSpy(&parser, &DataStreamParser::read);
+	auto limitSpy = QSignalSpy(&parser, &SplitParser::bufferLimitExceeded);
+	auto buffer = QByteArray();
+
+	parser.setMaximumBufferSize(4);
+	auto boundary = QByteArray("1234");
+	parser.parseBytes(boundary, buffer);
+	QCOMPARE(buffer, "1234");
+	QCOMPARE(limitSpy.count(), 0);
+
+	auto overflow = QByteArray("5");
+	parser.parseBytes(overflow, buffer);
+	QCOMPARE(buffer, "");
+	QCOMPARE(limitSpy.count(), 1);
+	QCOMPARE(limitSpy.takeFirst().at(0).toLongLong(), 5);
+
+	auto recovered = QByteArray("ok\n");
+	parser.parseBytes(recovered, buffer);
+	QCOMPARE(readSpy.count(), 1);
+	QCOMPARE(readSpy.takeFirst().at(0).toString(), "ok");
+	QCOMPARE(buffer, "");
+}
+
 QTEST_MAIN(TestSplitParser);
